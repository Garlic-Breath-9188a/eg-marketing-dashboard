# Copy to secrets.toml and fill in. NEVER commit secrets.toml.

# HubSpot Service Key (replaces legacy Private App).
# Create at: HubSpot → Settings → Integrations → Service Keys
# Required scopes:
#   crm.objects.contacts.read, crm.objects.companies.read,
#   crm.schemas.contacts.read, crm.schemas.companies.read,
#   forms, marketing.campaigns.read,
#   crm.objects.deals.read, crm.objects.owners.read  (for deals + tasks pipeline KPIs)
HUBSPOT_TOKEN = "pat-na1-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"

# AuthoredUp API key — Settings → API Access in AuthoredUp web app.
AUTHOREDUP_API_KEY = "your-32-char-authoredup-key"

# Shared password for the dashboard. Rotate periodically.
DASHBOARD_PASSWORD = "change-me-before-deploying"

# WordPress / Jetpack integration for WealthTechToday.com Content tab.
# WORDPRESS_BASE_URL: required, the site URL (no trailing slash)
WORDPRESS_BASE_URL = "https://wealthtechtoday.com"
# WORDPRESS_USER + WORDPRESS_APP_PASSWORD: optional, only needed to read drafts/private posts.
# Generate an app password at WordPress admin → Users → Profile → Application Passwords.
WORDPRESS_USER = ""
WORDPRESS_APP_PASSWORD = ""
# WPCOM_API_TOKEN + WPCOM_SITE: optional, for Jetpack/WordPress.com view stats.
# Generate at https://developer.wordpress.com/apps/ → create app → get OAuth bearer token.
WPCOM_API_TOKEN = ""
WPCOM_SITE = "wealthtechtoday.com"
